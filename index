            if(!grid || !blockGrid) return;
            
            grid.innerHTML = '';
            blockGrid.innerHTML = '';

            timeSlots.forEach(t => {
                const isBlocked = blockedSlots.includes(t);
                grid.innerHTML += `<button onclick="openBookingStep1('${t}')" class="slot-btn bg-white p-4 rounded-2xl shadow-sm text-teal-700 font-bold text-xs ${isBlocked ? 'blocked' : ''}" ${isBlocked ? 'disabled' : ''}>${t}</button>`;
                blockGrid.innerHTML += `<button onclick="toggleBlock('${t}')" class="p-2 border rounded-xl text-[10px] font-bold ${isBlocked ? 'bg-red-500 text-white border-red-600' : 'bg-slate-50'}">${t}</button>`;
            });
        }

        function toggleBlock(t) {
            if(blockedSlots.includes(t)) blockedSlots = blockedSlots.filter(s => s !== t);
            else blockedSlots.push(t);
            initSlots();
        }

        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            if(sidebar.classList.contains('-translate-x-full')) {
                sidebar.classList.remove('-translate-x-full');
                overlay.style.display = 'block';
            } else {
                sidebar.classList.add('-translate-x-full');
                overlay.style.display = 'none';
            }
        }

        function changeLanguage(lang) {
            document.querySelectorAll('[data-i18n]').forEach(el => {
                el.innerText = translations[lang][el.getAttribute('data-i18n')];
            });
        }

        let currentSlot = "";
        function openBookingStep1(time) {
            currentSlot = time;
            document.getElementById('displaySlot').innerText = time;
            document.getElementById('bookingModal').style.display = 'flex';
            document.getElementById('step1').classList.remove('hidden-view');
            document.getElementById('step2').classList.add('hidden-view');
        }

        function goToStep2() {
            const name = document.getElementById('pName').value;
            const phone = document.getElementById('pPhone').value;
            if(!name || !phone) return alert("Please enter Patient Name and Phone Number");
            document.getElementById('step1').classList.add('hidden-view');
            document.getElementById('step2').classList.remove('hidden-view');
        }

        function payUPI() {
            window.location.href = `upi://pay?pa=7904023256@okbizaxis&pn=SangeethaPhysio&am=100&cu=INR`;
        }

        function confirmFinalBooking() {
            const name = document.getElementById('pName').value;
            const template = document.getElementById('waTemplate').value;
            const finalMsg = template.replace("[Patient Name]", name).replace("[Sangeetha Physio Genics]", "Sangeetha Physio Genics").replace("[Date]", "Today").replace("[Time]", currentSlot).replace("[Phone Number]", "79040 23256");
            
            alert("Payment Recorded! Sending your WhatsApp Confirmation...");
            window.open("https://wa.me/917904023256?text=" + encodeURIComponent(finalMsg));
            closeModal();
        }

        function closeModal() { document.getElementById('bookingModal').style.display = 'none'; }

        function showAdminLogin() {
            document.getElementById('patientView').classList.add('hidden-view');
            document.getElementById('loginView').classList.remove('hidden-view');
        }

        function login() {
            const u = document.getElementById('user').value;
            const p = document.getElementById('pass').value;
            if((u === 'Dr_Sangeetha_R' && p === 'Genics@2024') || (u === 'Dillip' && p === 'Dillip')) {
                document.getElementById('lmsUser').innerText = "Logged as: " + u;
                document.getElementById('accName').value = (u === 'Dillip') ? 'Dillip' : 'Dr. Sangeetha R';
                document.getElementById('loginView').classList.add('hidden-view');
                document.getElementById('adminView').classList.remove('hidden-view');
                initLMS();
            } else { alert('Access Denied: Wrong Username or Password'); }
        }

        function initLMS() {
            setInterval(() => {
                document.getElementById('checkInTime').innerText = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            }, 1000);
            initSlots();
        }

        function saveCheckIn() {
            const treatment = document.getElementById('treatmentSelect').value;
            if(treatment === "-- Select Treatment --") return alert("Please select a treatment from the list");
            alert("Patient Checked-in successfully for: " + treatment);
        }

        function logout() { location.reload(); }

        function showSection(id) {
            document.querySelectorAll('.admin-sect').forEach(s => s.classList.add('hidden-view'));
            document.getElementById('sect-'+id).classList.remove('hidden-view');
            document.getElementById('lmsTitle').innerText = id.replace('sect-', '').toUpperCase();
            if(window.innerWidth < 768) toggleSidebar();
        }

        function refreshGoogleReviews() {
            alert("Connecting to Google Maps Listing... 32 Reviews synchronized. Refreshing image cache...");
        }

        function resetTemplate() {
            document.getElementById('waTemplate').value = "Hi [Patient Name], your physio appointment at [Sangeetha Physio Genics] is confirmed for [Date] at [Time]. If any changes please reach out to [Phone Number].";
        }

        window.onload = initSlots;
    </script>
</body>
</html>
